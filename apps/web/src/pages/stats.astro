---
import Layout from "../layouts/Layout.astro";
import { StatsContent } from "../components/stats-content";
---

<Layout title="Stats Dashboard - WeAreOur Games">
  <header class="page-header">
    <a href="/" class="games-logo">Games</a>
  </header>

  <div class="stats-page">
    <div class="header-content">
      <h1>Learning Dashboard</h1>
    </div>

    <div class="page-main" id="stats-content">
      <StatsContent client:load />
    </div>

    <footer class="page-footer">
    </footer>
  </div>
</Layout>



<style is:global>
  * {
    box-sizing: border-box;
  }

  .stats-page {
    display: flex;
    flex-direction: column;
    min-height: 100vh;
  }

  /* === HEADER === */
  .page-header {
    padding: 24px 20px;
    display: flex;
    width: 100%;
    justify-content: start;
    align-items: center;
    gap: 20px;
  }

  .games-logo {
    font-size: 28px;
    font-weight: 800;
    color: #333;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s ease;
    letter-spacing: -1px;
    min-width: 100px;
    flex-shrink: 0;
  }

  .games-logo:hover {
    color: #667eea;
    transform: scale(1.05);
  }

  .games-logo:active {
    transform: scale(0.98);
  }

  .header-content {
    max-width: 1000px;
    margin: 0 auto;
    flex: 1;
  }

  .page-header h1 {
    margin: 0;
    font-size: 32px;
    font-weight: 700;
    color: #000;
  }

  /* === MAIN CONTENT === */
  .page-main {
    flex: 1;
    padding: 30px 20px;
    max-width: 1000px;
    width: 100%;
    margin: 0 auto;
  }

  /* === FOOTER === */
  .page-footer {
    padding: 20px;
    text-align: center;
  }

  /* === RESPONSIVE === */
  @media (max-width: 768px) {
    .stats-page {
      min-height: auto;
    }

    .page-header {
      padding: 20px 16px;
    }

    .page-header h1 {
      font-size: 24px;
    }

    .page-main {
      padding: 20px 16px;
    }
  }

  @media (max-width: 480px) {
    .page-header h1 {
      font-size: 20px