---
import Layout from "./Layout.astro";

interface Props {
  title: string;
  description: string;
  backLink?: string | null;
  backLabel?: string;
  showDashboard?: boolean;
}

const { 
  title, 
  description, 
  backLink = "/",
  backLabel = "← Back",
  showDashboard = false
} = Astro.props;
---

<Layout title={title}>
  <div class="menu-page-layout">
    <header class="menu-header">
      {backLink && (
        <a href={backLink} class="back-link">{backLabel}</a>
      )}
      
      <div class="header-content">
        <h1>{title}</h1>
        <p>{description}</p>
      </div>

      {showDashboard && (
        <a href="/stats" class="stats-link">📊 Dashboard</a>
      )}
    </header>

    <div class="menu-content">
      <slot />
    </div>

    <footer class="menu-footer">
      <slot name="footer" />
    </footer>
  </div>
</Layout>

<style>
  .menu-page-layout {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 2rem;
    min-height: 100vh;
    width: 100%;
  }

  .menu-header {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 3rem;
    color: black;
    position: relative;
    min-width: 0;
    gap: 2rem;
    flex-wrap: wrap;
  }

  .back-link {
    color: black;
    text-decoration: none;
    font-size: 1rem;
    transition: opacity 0.3s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .back-link:hover {
    opacity: 0.6;
  }

  .header-content {
    flex: 1;
    text-align: center;
    min-width: 250px;
  }

  .header-content h1 {
    font-size: 3rem;
    margin: 0;
  }

  .header-content p {
    font-size: 1.1rem;
    margin: 0.5rem 0 0 0;
    opacity: 0.8;
  }

  .stats-link {
    background: #f0f0f0;
    color: black;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-size: 1rem;
    transition: background 0.3s;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .stats-link:hover {
    background: #e0e0e0;
  }

  .menu-content {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    width: 100%;
    max-width: 1200px;
    margin-bottom: 3rem;
  }

  .menu-footer {
    color: black;
    text-align: center;
    margin-top: 3rem;
  }

  @media (max-width: 768px) {
    .menu-page-layout {
      padding: 1rem;
    }

    .menu-header {
      margin-bottom: 2rem;
      gap: 1rem;
    }

    .header-content h1 {
      font-size: 2rem;
    }

    .header-content p {
      font-size: 1rem;
    }

    .menu-content {
      gap: 1rem;
    }
  }
</style>
