---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  buttonText?: string;
}

const { icon, title, description, href, buttonText = "Play Now" } = Astro.props;
---

<div class="game-card">
  <div class="game-icon">{icon}</div>
  <h2>{title}</h2>
  <p>{description}</p>
  <a href={href} class="game-button">{buttonText}</a>
</div>

<style>
  .game-card {
    background: rgba(255, 255, 255, 0.6);
    backdrop-filter: blur(15px);
    border-radius: 12px;
    padding: 2rem;
    text-align: center;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s, box-shadow 0.3s;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .game-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.2);
  }

  .game-icon {
    font-size: 3rem;
  }

  .game-card h2 {
    margin: 0;
    color: #333;
    font-size: 1.5rem;
  }

  .game-card p {
    margin: 0;
    color: #666;
    flex-grow: 1;
  }

  .game-button {
    display: inline-block;
    background: #667eea;
    color: white;
    padding: 0.75rem 2rem;
    border-radius: 6px;
    text-decoration: none;
    font-weight: 600;
    transition: opacity 0.3s;
    align-self: center;
  }

  .game-button:hover {
    opacity: 0.9;
  }
</style>
